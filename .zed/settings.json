{
  "code_actions_on_format": {
    "source.fixAll.biome": true,
    "source.organizeImports.biome": true
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.tanstack",
    "**/.wrangler",
    "**/node_modules",
    "codedb.snapshot",
    ".coverage"
  ],
  "format_on_save": "on",
  "formatter": {
    "language_server": {
      "name": "biome"
    }
  },
  "language_servers": [
    "!eslint",
    "!typescript-language-server",
    "!vtsls",
    "!markdownlint",
    "..."
  ]
}
